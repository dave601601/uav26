<?xml version="1.0"?>
<model>
  <name>uav26_quad</name>
  <version>1.0</version>
  <sdf version="1.10">model.sdf</sdf>
  <description>
    UAV26 X-frame quadrotor for line_tracer closed-loop validation.
    Mounts a downward color + depth camera (D435 사양 모사), a sideways and a
    front camera, and four motor-model plugins driven by fc_sim_node.
  </description>
  <author>
    <name>Dongha Gwak</name>
    <email></email>
  </author>
</model>
