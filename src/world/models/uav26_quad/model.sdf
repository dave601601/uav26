<?xml version="1.0"?>
<!--
  UAV26 X-frame quadrotor.

  Mass, arm geometry, and inertia match the STM32 firmware constants:
    mass    = 1.182 kg            (controller.c: mass_org)
    dx      = 0.1827 m            (controller.c: dx)
    dy      = 0.1676 m            (controller.c: dy)
  Inertia is rescaled from the previous 1.5 kg approximation by the
  mass ratio; revisit if attitude oscillation appears under fc_sim.

  Body: FLU (REP-103). +x forward, +y left, +z up. base_link is at the
  drone CoM. The fc_sim node converts to the firmware's NED body frame
  with a one-shot axis-flip at the IMU subscriber + motor publisher.

  Camera mount: 드론 하단 중앙 (0, 0, -0.05), 광축 = -Z_body (수직 하향).
  Camera optical frame: ROS REP-103 — +X right, +Y down, +Z forward (= 광축).
  Camera yaw offset = 0 → 드론 +X(forward) 가 image 의 v-up 방향.

  Rotor 번호 (PX4 X-frame 관례; physical position in body FLU):
    rotor_0 : front-right, CCW
    rotor_1 : back-left,   CCW
    rotor_2 : front-left,  CW
    rotor_3 : back-right,  CW

  Plugins:
    - 4 × gz-sim-multicopter-motor-model-system (per-rotor thrust dynamics)
    - gz-sim-odometry-publisher-system (ground-truth /odom_truth)

  Motor model: 2212 920KV on 4S (the real power train), 9450/1045-class
  props. maxRotVelocity 1050 rad/s ~= 10000 rpm loaded (920 kV x 14.8 V
  no-load = 13600 rpm; ~74 % under prop load). motorConstant 8.0e-06
  gives k_f * w_max^2 = 8.82 N ~= 900 gf max thrust per motor, the
  middle of published bench numbers for this motor/prop/battery combo.
  Total max thrust 35.3 N vs 11.6 N weight -> hover at thrust_norm 0.33.
  Must stay consistent with fc_core controller.c max_thrust_g_per_motor
  and fc_sim_node kDefaultMotorConstant / max_motor_omega.

  The previous gz-sim-multicopter-control-system (fake FC) has been
  removed; the simulated FC is now fc_sim_node running fc_core.
-->
<sdf version="1.10">
  <model name="uav26_quad">
    <pose>0 0 0 0 0 0</pose>

    <!-- ===== base_link ===== -->
    <link name="base_link">
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1.182</mass>
        <inertia>
          <ixx>0.0107</ixx>
          <iyy>0.0107</iyy>
          <izz>0.0189</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <visual name="body_visual">
        <geometry>
          <box>
            <size>0.20 0.20 0.05</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.2 0.2 0.2 1</diffuse>
        </material>
      </visual>

      <visual name="arm_x_visual">
        <geometry>
          <box>
            <size>0.40 0.03 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <visual name="arm_y_visual">
        <geometry>
          <box>
            <size>0.03 0.40 0.02</size>
          </box>
        </geometry>
        <material>
          <ambient>0.15 0.15 0.15 1</ambient>
          <diffuse>0.25 0.25 0.25 1</diffuse>
        </material>
      </visual>

      <!-- 전방 표시 (시각화용 빨간 점) -->
      <visual name="forward_indicator">
        <pose>0.10 0 0.03 0 0 0</pose>
        <geometry>
          <box>
            <size>0.04 0.04 0.005</size>
          </box>
        </geometry>
        <material>
          <ambient>0.6 0.0 0.0 1</ambient>
          <diffuse>0.9 0.0 0.0 1</diffuse>
        </material>
      </visual>

      <!-- Four sphere feet instead of one CoM sphere. The single 5 cm
           sphere made the drone literally a ball: one contact point,
           no support polygon (tipped over when landing motors-off,
           r49) and zero rolling resistance (a disarmed drone with
           residual velocity rolled 6 m across the arena after a clean
           touchdown, r53). Four small spheres at the arm tips give a
           0.20 m square support polygon (tip angle ~63 deg with CoM
           5 cm up) and slide-with-friction instead of rolling; the
           earlier 0.40 m box wedged on its EDGES, which point feet
           don't have. Contact height stays -0.05 m so spawn/landing
           altitudes are unchanged. -->
      <collision name="foot_fr">
        <pose>0.10 -0.10 -0.03 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <collision name="foot_fl">
        <pose>0.10 0.10 -0.03 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <collision name="foot_br">
        <pose>-0.10 -0.10 -0.03 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <collision name="foot_bl">
        <pose>-0.10 0.10 -0.03 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>

      <!-- ===== 하향 D435 카메라 mesh (visual only) =====
           realsense2_description 의 d435.dae 를 그대로 가져왔다.
           DAE 내부 좌표는 URDF 의 (rpy = π/2, 0, π/2) 로 link X-forward 정렬되도록
           설계됐고, 우리는 거기에 추가로 pitch=+π/2 (X-forward → Z-down) 를 합성해야
           한다. Rz(π/2)·Ry(π/2)·Rx(π/2) 합성을 RPY 로 풀면 (π, 0, π/2) 이므로
           아래 pose 의 rpy 로 이 한 번에 표현한다. -->
      <visual name="d435_visual">
        <pose>0 0 -0.05 3.141592653589793 0 1.5707963267948966</pose>
        <geometry>
          <mesh>
            <uri>model://world_assets/meshes/d435.dae</uri>
          </mesh>
        </geometry>
      </visual>

      <!-- ===== 하향 D435 카메라 sensor (color + depth) =====
           pose pitch=+π/2 → Gazebo camera +X (view) 가 -Z_body (정확히 하향).
           Frame name 은 ROS optical 표준 (camera_color/depth_optical_frame)
           으로 명시 → ros_gz_bridge 가 image header.frame_id 를 그대로 노출. -->
      <sensor name="color" type="camera">
        <pose>0 0 -0.05 0 1.5707963267948966 0</pose>
        <topic>uav26_quad/camera/color/image</topic>
        <gz_frame_id>camera_color_optical_frame</gz_frame_id>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.20428</horizontal_fov>  <!-- 69° in rad -->
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.05</near>
            <far>100.0</far>
          </clip>
        </camera>
        <always_on>1</always_on>
      </sensor>

      <sensor name="depth" type="depth_camera">
        <pose>0 0 -0.05 0 1.5707963267948966 0</pose>
        <topic>uav26_quad/camera/depth/image</topic>
        <gz_frame_id>camera_depth_optical_frame</gz_frame_id>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.20428</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R_FLOAT32</format>
          </image>
          <clip>
            <near>0.05</near>
            <far>100.0</far>
          </clip>
          <depth_camera>
            <clip>
              <near>0.3</near>
              <far>3.0</far>
            </clip>
          </depth_camera>
        </camera>
        <always_on>1</always_on>
      </sensor>

      <!-- ===== Sideways lookahead camera (OV9281 1280x800 mono + 6 mm) =====
           Models the real OV9281 global-shutter sensor (3 um px, 1/4"):
           f = 6 mm / 3 um = 2000 px -> horizontal_fov = 2*atan(640/2000)
           = 0.6196 rad (35.5 deg), VFOV 22.6 deg.
           Mount: boresight = +Y_body depressed 22 deg. SDF rpy composes
           R = Rz(yaw)*Ry(pitch), so (r p y) = (0, 0.384, pi/2) maps the
           gz-camera view axis +X -> (0, cos22, -sin22) in body frame.
           At 2 m altitude the VFOV band covers lateral ground distance
           3.05..10.6 m; the adjacent sweep row (+4 m) is the load-bearing
           target. This is what lets the serpentine skip every other row.
           Sim renders at HALF the real sensor resolution (640x400,
           f=1000 px) purely for RTF: full 1280x800 halved host RTF
           (0.67 -> 0.37). The +4 m row still gets ~6.3 px/module
           (detects fine); only the opportunistic +8 m band is lost.
           Real hardware has 2x this pixel budget, so sim detection
           performance is the conservative bound. -->
      <sensor name="lookahead" type="camera">
        <pose>0 0.05 -0.03 0 0.384 1.5707963267948966</pose>
        <topic>uav26_quad/camera/lookahead/image</topic>
        <gz_frame_id>lookahead_optical_frame</gz_frame_id>
        <update_rate>10</update_rate>
        <camera>
          <horizontal_fov>0.6196</horizontal_fov>
          <image>
            <width>640</width>
            <height>400</height>
            <format>L8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>30.0</far>
          </clip>
        </camera>
        <always_on>1</always_on>
      </sensor>

      <!-- IMU (line_tracer 는 사용 안 하지만 가짜 FC 가 angular rate 추정에 씀) -->
      <sensor name="imu" type="imu">
        <topic>uav26_quad/imu</topic>
        <gz_frame_id>base_link</gz_frame_id>
        <update_rate>200</update_rate>
        <always_on>1</always_on>
      </sensor>
    </link>

    <!-- ===== rotor_0 : front-right, CCW ===== -->
    <link name="rotor_0">
      <pose>0.1827 -0.1676 0.05 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>9.75e-07</ixx>
          <iyy>4.17e-05</iyy>
          <izz>4.26e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.005</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ===== rotor_1 : back-left, CCW ===== -->
    <link name="rotor_1">
      <pose>-0.1827 0.1676 0.05 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>9.75e-07</ixx>
          <iyy>4.17e-05</iyy>
          <izz>4.26e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.005</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.4 0.4 0.4 1</ambient>
          <diffuse>0.6 0.6 0.6 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ===== rotor_2 : front-left, CW ===== -->
    <link name="rotor_2">
      <pose>0.1827 0.1676 0.05 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>9.75e-07</ixx>
          <iyy>4.17e-05</iyy>
          <izz>4.26e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.005</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.4 0.0 0.0 1</ambient>
          <diffuse>0.7 0.0 0.0 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ===== rotor_3 : back-right, CW ===== -->
    <link name="rotor_3">
      <pose>-0.1827 -0.1676 0.05 0 0 0</pose>
      <inertial>
        <mass>0.005</mass>
        <inertia>
          <ixx>9.75e-07</ixx>
          <iyy>4.17e-05</iyy>
          <izz>4.26e-05</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.10</radius>
            <length>0.005</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.4 0.0 0.0 1</ambient>
          <diffuse>0.7 0.0 0.0 1</diffuse>
        </material>
      </visual>
    </link>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_3</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
        <dynamics>
          <damping>0.005</damping>
        </dynamics>
      </axis>
    </joint>

    <!-- ===== Multicopter motor model: 각 rotor 추력 시뮬 ===== -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1050.0</maxRotVelocity>
      <motorConstant>8.0e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <actuator_number>0</actuator_number>
      <rotorDragCoefficient>0.0</rotorDragCoefficient>
      <rollingMomentCoefficient>0.0</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/0</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1050.0</maxRotVelocity>
      <motorConstant>8.0e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <actuator_number>1</actuator_number>
      <rotorDragCoefficient>0.0</rotorDragCoefficient>
      <rollingMomentCoefficient>0.0</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/1</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1050.0</maxRotVelocity>
      <motorConstant>8.0e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <actuator_number>2</actuator_number>
      <rotorDragCoefficient>0.0</rotorDragCoefficient>
      <rollingMomentCoefficient>0.0</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/2</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system"
            name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1050.0</maxRotVelocity>
      <motorConstant>8.0e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <actuator_number>3</actuator_number>
      <rotorDragCoefficient>0.0</rotorDragCoefficient>
      <rollingMomentCoefficient>0.0</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/3</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- 디버그용 ground-truth odometry — 기본 토픽 /model/uav26_quad/odometry.
         fc_sim_node also uses pose.position.z as the altitude reading
         in lieu of a dedicated downward range sensor. -->
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
    </plugin>
  </model>
</sdf>
